# =============================================================================
# RetailFlow Pipeline — .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# --- Virtual environments ---
.venv/
.venv-dbt/
.venv.bak/
venv/
env/
ENV/

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Environment ---
.env
*.env.local

# --- Data ---
data/raw/*
data/processed/*
data/rejected/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/rejected/.gitkeep

# --- Airflow ---
airflow/logs/
airflow/airflow.cfg
airflow/airflow.db
airflow/webserver_config.py

# --- dbt ---
dbt/logs/
dbt/target/
dbt/dbt_packages/
dbt/.user.yml

# --- Great Expectations ---
great_expectations/uncommitted/
great_expectations/.ge_store_backend/

# --- Docker ---
docker-compose.override.yml

# --- Outputs ---
outputs/*
!outputs/.gitkeep

# --- Logs ---
*.log
logs/

# --- Test artifacts ---
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/

# --- Temp scripts ---
tmp_*.py
*.tmp
