# =============================================================================
# RetailFlow Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE for Docker users: docker-compose.yml overrides POSTGRES_HOST to "db"
# inside the container network.  Local tools (psql, dbt, Airflow) on the host
# use the value from .env (localhost).
# =============================================================================

# --- PostgreSQL Connection ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retailflow
POSTGRES_USER=retailflow_user
POSTGRES_PASSWORD=retailflow_pass

# --- Airflow Configuration ---
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_EMAIL=admin@example.com

# --- Data Generation ---
NUM_CUSTOMERS=10000
NUM_PRODUCTS=500
NUM_ORDERS=100000

# --- dbt Configuration ---
DBT_STAGING_SCHEMA=staging
DBT_INTERMEDIATE_SCHEMA=intermediate
DBT_MARTS_SCHEMA=marts

# --- Alerting (Webhook) ---
# Set this to a Slack or Discord webhook URL to receive pipeline alerts.
# Leave empty to disable alerting.
PIPELINE_WEBHOOK_URL=
